      {
        "tab": "Início",
        "groups": [
          {
            "group": "Começando",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Referência",
            "pages": ["config", "billing"]
          },
          {
            "group": "Novidades",
            "pages": ["changelog"]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Visão Geral",
            "pages": ["cli/overview"]
          },
          {
            "group": "Autenticação",
            "pages": ["cli/login"]
          },
          {
            "group": "Deploy",
            "pages": ["cli/deploy", "cli/link"]
