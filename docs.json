{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Nivo",
  "theme": "mint",
  "colors": {
    "primary": "#7C3AED",
    "light": "#a78bfa",
    "dark": "#5b21b6"
  },
  "topbarCtaButton": {
    "name": "Abrir Dashboard",
    "url": "https://nivo.lat"
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/YgorTailer/nivo"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Começando",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/overview",
              "sdk/client",
              "sdk/commit",
              "sdk/apps",
              "sdk/databases",
              "sdk/storage",
              "sdk/files",
              "sdk/auth"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/auth",
              "cli/deploy",
              "cli/link",
              "cli/apps",
              "cli/deployments",
              "cli/logs"
            ]
          },
          {
            "group": "Referência",
            "pages": ["config", "billing", "changelog"]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/YgorTailer/nivo"
  },
  "logo": "/images/logo(2).png"
}
