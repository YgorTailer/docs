        "groups": [
          {
            "group": "Visão Geral",
            "pages": ["sdk/overview", "sdk/client"]
          },
          {
            "group": "Apps",
            "pages": ["sdk/apps"]
          },
          {
            "group": "Bancos de Dados",
            "pages": ["sdk/databases"]
          },
          {
            "group": "Storage",
            "pages": ["sdk/storage"]
          },
          {
            "group": "Avançado",
            "pages": ["sdk/commit"]
          }
        ]
      }
    ]
